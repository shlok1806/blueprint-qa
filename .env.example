# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/blueprintqa

# Anthropic — get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
MAX_PAGES_PER_DOCUMENT=10
STORAGE_BACKEND=local   # "local" or "azure"

# Azure Blob Storage (only needed if STORAGE_BACKEND=azure)
AZURE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=blueprintqa
